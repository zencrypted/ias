[{form, [{registry, [bpe_row, bpe_create, bpe_pass, bpe_trace]}]},
	{ias, [
		{vpn_admin_url, "http://localhost:8080/api/admin/summary"},
		{vpn_provisioning_transport, erlang_rpc},
		{vpn_provisioning_vpn_node, 'vpn@127.0.0.1'},
		{vpn_provisioning_rpc_timeout, 5000},
		{vpn_event_retry_interval_ms, 5000},
		{vpn_dynamic_allocation_reservation, true},
		{vpn_dynamic_pair_delivery, true},
		{vpn_dynamic_pair_rpc_timeout, 30000},
		{vpn_provisioning_runtime_peer_id, client_a},
		{vpn_provisioning_runtime_peer_slots, #{alice => client_a, bob => client_b}},
		{kvs_transaction_provider, ias_kvs_transaction_mnesia},
		{certificate_material_protection_provider,
		 ias_certificate_material_protection_public},
		{certificate_material_staged_ttl_seconds, 86400},
		{certificate_validation_mode, strict},
		{ca_trust_anchor_file, "../ca/synrc/ecc/secp384r1/ca.pem"},
		{ca_trust_anchor_base_dir, "."}
	]},
	{bert, [{js, "priv/static"}]},
	{n2o, [{port, 8041},
		{app, ias},
		{upload, './priv/static/'},
		{trace, true},
		{routes, ias_route},
		{mq, n2o_syn},
		{formatter, n2o_bert},
		{protocols, [n2o_heart, nitro_n2o, n2o_ftp, bpe_n2o]},
		{session, n2o_session},
		{origin, <<"*">>},
		{pickler, n2o_secret},
		{event, pickle}]},
	{kvs, [{dba, kvs_mnesia},
		{mnesia_media, disc_copies},
		{dba_seq, kvs_mnesia},
		{dba_st, kvs_stream},
		{schema, [kvs, kvs_stream, ias_kvs, bpe_metainfo]}]}
].
